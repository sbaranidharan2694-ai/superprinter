# Super Printers — Hostinger LiteSpeed config
# Without this file every client-side route (/wedding-cards, /contact, etc.)
# returns 404 from the server, hiding the entire site from crawlers and direct
# visitors. The Netlify-style _redirects file in this directory is ignored by
# LiteSpeed.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ── Canonical host: force apex (drop www) and HTTPS ────────────────────────
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.superprinters\.net$ [NC]
  RewriteRule ^(.*)$ https://superprinters.net/$1 [R=301,L]

  # ── 301 redirects: rename area pages to /printing-press-{area} ─────────────
  RewriteRule ^tambaram-printing/?$         /printing-press-tambaram         [R=301,L]
  RewriteRule ^chromepet-printing/?$        /printing-press-chromepet        [R=301,L]
  RewriteRule ^pammal-printing/?$           /printing-press-pammal           [R=301,L]
  RewriteRule ^perungalathur-printing/?$    /printing-press-perungalathur    [R=301,L]
  RewriteRule ^velachery-printing/?$        /printing-press-velachery        [R=301,L]
  RewriteRule ^nanganallur-printing/?$      /printing-press-nanganallur      [R=301,L]
  RewriteRule ^medavakkam-printing/?$       /printing-press-medavakkam       [R=301,L]
  RewriteRule ^guindy-printing/?$           /printing-press-guindy           [R=301,L]
  RewriteRule ^adyar-printing/?$            /printing-press-adyar            [R=301,L]

  # ── SPA fallback: serve index.html for any non-file, non-directory path ────
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# ── Caching: long for hashed assets, short for index.html ───────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(?:js|css|woff2?|ttf|otf|eot|svg|ico|png|jpg|jpeg|gif|webp|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# ── Compression ─────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml text/xml application/xml
</IfModule>

# Pretty 404 → SPA also handles /404 internally
ErrorDocument 404 /index.html
