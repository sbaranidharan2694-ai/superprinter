# Super Printers — Hostinger LiteSpeed config
#
# Two responsibilities:
#  1. Force canonical host (https + apex, no www).
#  2. Serve prerendered route directories so crawlers see real HTML on first
#     response — falling back to the SPA shell only for unknown paths.
#
# IMPORTANT: this file must be present in the *deployed root*. Some FTP clients
# skip dot-files by default — make sure .htaccess is included in your upload.

Options -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ── Canonical host: force apex + HTTPS + strip trailing slash in ONE hop ─
  # Combined into a single 301 so a request like
  # http://www.superprinters.net/about/ does ONE redirect to
  # https://superprinters.net/about (not www→apex then /→no-/ which bled
  # PageRank and added an extra RTT to LCP for crawler-driven traffic).
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [OR]
  RewriteCond %{HTTP_HOST} ^www\.superprinters\.net$ [NC] [OR]
  RewriteCond %{REQUEST_URI} ^(.+)/$
  RewriteRule ^(.*?)/?$ https://superprinters.net/$1 [R=301,L]

  # ── Legacy /services/<slug> → flat product URL (kill duplicate clusters) ─
  # `/services/visiting-cards` and `/visiting-cards` rendered the same body
  # and self-canonicalized to themselves, splitting PageRank between the
  # two URLs. Permanent 301 onto the flat URL consolidates link equity
  # onto a single canonical and prevents the duplicate-content downgrade
  # Google has applied since the March 2024 core update.
  RewriteRule ^services/visiting-cards/?$       /visiting-cards          [R=301,L]
  RewriteRule ^services/wedding-invitations/?$  /wedding-cards           [R=301,L]
  RewriteRule ^services/brochure-printing/?$    /brochures               [R=301,L]
  RewriteRule ^services/bill-books/?$           /bill-books              [R=301,L]
  RewriteRule ^services/letterheads/?$          /letterheads             [R=301,L]
  RewriteRule ^services/banner-printing/?$      /banners                 [R=301,L]
  RewriteRule ^services/stickers-labels/?$      /stickers                [R=301,L]
  RewriteRule ^services/rubber-stamps/?$        /rubber-stamps           [R=301,L]
  RewriteRule ^services/catalogues/?$           /catalogues              [R=301,L]
  RewriteRule ^services/id-cards/?$             /pvc-id-cards            [R=301,L]

  # ── Legacy URL → canonical area pages ────────────────────────────────────
  RewriteRule ^tambaram-printing/?$         /printing-press-tambaram         [R=301,L]
  RewriteRule ^chromepet-printing/?$        /printing-press-chromepet        [R=301,L]
  RewriteRule ^pammal-printing/?$           /printing-press-pammal           [R=301,L]
  RewriteRule ^perungalathur-printing/?$    /printing-press-perungalathur    [R=301,L]
  RewriteRule ^velachery-printing/?$        /printing-press-velachery        [R=301,L]
  RewriteRule ^nanganallur-printing/?$      /printing-press-nanganallur      [R=301,L]
  RewriteRule ^medavakkam-printing/?$       /printing-press-medavakkam       [R=301,L]
  RewriteRule ^guindy-printing/?$           /printing-press-guindy           [R=301,L]
  RewriteRule ^adyar-printing/?$            /printing-press-adyar            [R=301,L]

  # ── Serve prerendered HTML when /<route>/index.html exists ───────────────
  # This is what makes the site crawlable without executing JS.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
  RewriteRule ^(.*)$ /$1/index.html [L]

  # ── Unknown routes → real HTTP 404 (avoid soft-404) ──────────────────────
  # We deliberately do NOT fall back to /index.html with a 200 status for
  # paths that have no prerendered HTML. Doing that produced soft-404s on
  # typo URLs (Google: "Crawled — currently not indexed (soft 404)"). The
  # ErrorDocument directive below serves /404.html with the prerendered
  # NotFound markup, while the server emits a real 404 status code.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ - [R=404,L]
</IfModule>

# ── Custom 404 (prerendered NotFound with noindex,nofollow) ────────────────
ErrorDocument 404 /404.html

# ── Caching ─────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(?:js|css|woff2?|ttf|otf|eot|svg|ico|png|jpg|jpeg|gif|webp|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  # HSTS — bumped to 1 year (31,536,000 s) which is the minimum the
  # Chromium HSTS preload list requires. Submit at hstspreload.org to
  # be added to browser shipped lists.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # ── Content Security Policy ─────────────────────────────────────────
  # Locks down what scripts/styles/fonts/iframes the browser will execute.
  # Tuned to allow: inline JSON-LD blocks, GA4 (gtm + ga collector +
  # regional region1 endpoint), Google Fonts CSS+WOFF2, Google Maps embed
  # iframe, image hosts (broad https — tighten once we inventory all
  # third-party image sources). 'unsafe-inline' on script-src kept for
  # the inline ld+json blocks; tighten to hash/nonce once Vite is wired
  # for it. frame-ancestors 'self' replaces X-Frame-Options.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://www.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com https://region1.google-analytics.com; frame-src https://www.google.com https://maps.google.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests"

  # Permissions-Policy — explicitly disable browser features we don't use.
  # Defends against accidental opt-in by third-party scripts.
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=(), interest-cohort=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"

  # Cross-origin isolation — WhatsApp deeplinks open in a new tab via
  # window.open; same-origin-allow-popups keeps process-isolation while
  # permitting that flow.
  Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
  Header always set Cross-Origin-Resource-Policy "same-origin"
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# ── Compression ─────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml text/xml application/xml font/woff2
</IfModule>
